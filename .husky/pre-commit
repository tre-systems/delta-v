npm run lint
npm run typecheck:all
# Fresh coverage dir avoids occasional ENOENT on coverage/.tmp (stale merge state).
rm -rf coverage
npm run test:coverage
# Free port + no reuse: avoids clashing with dev servers or a stuck process on a fixed port.
E2E_PORT="$(node -e "const n=require('net');const s=n.createServer();s.listen(0,'127.0.0.1',()=>{process.stdout.write(String(s.address().port));s.close();});")"
export E2E_PORT
DELTAV_PRE_COMMIT_E2E=1 npm run test:e2e
npm run simulate all 25 -- --ci
