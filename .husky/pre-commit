staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"

if [ -z "$staged_files" ]; then
  exit 0
fi

is_doc_path() {
  case "$1" in
    README.md|AGENT_SPEC.md|docs/*|patterns/*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

run_boundary_checks() {
  # Grep-based boundary checks
  if grep -rn '\.innerHTML\s*=' src/client/ --include='*.ts' | grep -v 'dom.ts' | grep -v '\.test\.ts'; then
    echo "ERROR: Direct innerHTML assignment found outside dom.ts. Use setTrustedHTML() instead."
    exit 1
  fi

  if grep -rn 'Math\.random' src/shared/engine/ --include='*.ts' | grep -v '\.test\.ts' | grep -v '= Math\.random'; then
    echo "ERROR: Math.random found in engine code. Use injected rng parameter instead."
    exit 1
  fi

  if grep -rn 'console\.\(log\|warn\|error\)' src/shared/ --include='*.ts' | grep -v '\.test\.ts'; then
    echo "ERROR: console methods found in shared code. Shared layer must be side-effect free."
    exit 1
  fi
}

docs_only=1
while IFS= read -r path; do
  [ -z "$path" ] && continue
  if ! is_doc_path "$path"; then
    docs_only=0
    break
  fi
done <<EOF
$staged_files
EOF

if [ "$docs_only" -eq 1 ]; then
  echo "Documentation-only staged changes: running doc link checks."
  npm run check:doc-links
  exit 0
fi

echo "Running pre-commit checks: lint, boundary checks, typecheck."
npm run lint
run_boundary_checks
npm run typecheck:all
