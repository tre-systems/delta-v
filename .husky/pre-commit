npm run lint

# Grep-based boundary checks
if grep -rn '\.innerHTML\s*=' src/client/ --include='*.ts' | grep -v 'dom.ts' | grep -v '\.test\.ts'; then
  echo "ERROR: Direct innerHTML assignment found outside dom.ts. Use setTrustedHTML() instead."
  exit 1
fi

if grep -rn 'Math\.random' src/shared/engine/ --include='*.ts' | grep -v '\.test\.ts' | grep -v '= Math\.random'; then
  echo "ERROR: Math.random found in engine code. Use injected rng parameter instead."
  exit 1
fi

if grep -rn 'console\.\(log\|warn\|error\)' src/shared/ --include='*.ts' | grep -v '\.test\.ts'; then
  echo "ERROR: console methods found in shared code. Shared layer must be side-effect free."
  exit 1
fi

npm run typecheck:all
# Local D1 for wrangler dev during e2e (idempotent if already applied).
npx wrangler d1 migrations apply delta-v-telemetry --local
# Fresh coverage dir avoids occasional ENOENT on coverage/.tmp (stale merge state).
rm -rf coverage
mkdir -p coverage/.tmp
npm run test:coverage
# Free port + no reuse: avoids clashing with dev servers or a stuck process on a fixed port.
E2E_PORT="$(node -e "const n=require('net');const s=n.createServer();s.listen(0,'127.0.0.1',()=>{process.stdout.write(String(s.address().port));s.close();});")"
export E2E_PORT
DELTAV_PRE_COMMIT_E2E=1 npm run test:e2e
DELTAV_PRE_COMMIT_E2E=1 npm run test:e2e:a11y
npm run simulate all 40 -- --ci
