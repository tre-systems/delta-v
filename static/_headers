# Security headers applied to every static asset served by Cloudflare
# Workers Assets. Worker-served routes (e.g. /api/*) apply the same set
# via src/server/response-headers.ts — keep these two paths in sync.
#
# Docs: https://developers.cloudflare.com/workers/static-assets/headers/
#
# NB on `script-src 'unsafe-inline'`: matches.html, leaderboard.html and
# index.html each carry one inline <script> for page-level boot logic.
# Static `_headers` can't inject per-request nonces, so until those
# scripts move to external files (see BACKLOG entry) we allow inline
# scripts here. All the other headers (X-Frame-Options, HSTS, etc.)
# are still applied.

/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self' https://delta-v.tre.systems wss://delta-v.tre.systems ws://delta-v.tre.systems https://cloudflareinsights.com; img-src 'self' data: https://storage.ko-fi.com; base-uri 'self'; frame-ancestors 'none'; form-action 'self'

# Each build stamps `index.html` with `?v=<contenthash>` for the JS/CSS
# bundles (see scripts/bundle-style-css.mjs). The hash changes with the
# bytes, so the request URL itself acts as the cache key — `immutable`
# tells browsers never to revalidate the asset they already hold. New
# builds publish a different query and bypass the old cache entry.
/client.js
  Cache-Control: public, max-age=31536000, immutable

/style.css
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable
