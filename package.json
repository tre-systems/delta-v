{
  "name": "delta-v",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:client": "node esbuild.client.mjs",
    "build": "npm run build:client",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:watch": "vitest",
    "verify": "npm run lint && npm run typecheck && npm run test:coverage && npm run build && npm run test:e2e && npm run simulate all 25 -- --ci",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "simulate": "tsx scripts/simulate-ai.ts",
    "update-deps": "npx npm-check-updates -u && npm install",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.27.4",
    "fast-check": "^4.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.75.0",
    "ws": "^8.19.0"
  }
}
