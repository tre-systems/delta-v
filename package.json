{
  "name": "delta-v",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:client": "node esbuild.client.mjs",
    "build": "npm run build:client",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "simulate": "tsx scripts/simulate-ai.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@cloudflare/workers-types": "^4.20250214.0",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.27.4",
    "husky": "^9.1.7",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18",
    "wrangler": "^4.0.0",
    "ws": "^8.19.0"
  }
}
