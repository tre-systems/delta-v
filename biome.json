{
  "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always"
    }
  },
  "linter": {
    "rules": {
      "style": {
        "useConst": "error",
        "useTemplate": "error",
        "useExponentiationOperator": "error",
        "noNonNullAssertion": "error",
        "useNodejsImportProtocol": "error",
        "noNamespace": "error"
      },
      "complexity": {
        "useArrowFunction": "error",
        "useFlatMap": "error",
        "noForEach": "error",
        "noUselessSwitchCase": "error",
        "noUselessTypeConstraint": "error"
      },
      "suspicious": {
        "noVar": "error",
        "noExplicitAny": "error",
        "noDoubleEquals": "error",
        "noFallthroughSwitchClause": "error",
        "noGlobalAssign": "error",
        "noShadowRestrictedNames": "error"
      },
      "correctness": {
        "noUnusedVariables": "error",
        "noUnusedImports": "error",
        "noUndeclaredVariables": "error",
        "useExhaustiveDependencies": "error"
      },
      "performance": {
        "noAccumulatingSpread": "error",
        "noDelete": "error"
      }
    }
  },
  "overrides": [
    {
      "includes": ["src/server/**/*.ts", "packages/mcp-adapter/**/*.ts"],
      "linter": {
        "rules": {
          "correctness": {
            "noUndeclaredVariables": "off"
          }
        }
      }
    },
    {
      "includes": ["src/shared/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "../client": "shared/ must not import from client/ (layer boundary violation)",
                  "../../client": "shared/ must not import from client/ (layer boundary violation)",
                  "../server": "shared/ must not import from server/ (layer boundary violation)",
                  "../../server": "shared/ must not import from server/ (layer boundary violation)"
                }
              }
            }
          }
        }
      }
    },
    {
      "includes": ["src/client/**/*.ts"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "../server": "client/ must not import from server/ (layer boundary violation)",
                  "../../server": "client/ must not import from server/ (layer boundary violation)",
                  "../../../server": "client/ must not import from server/ (layer boundary violation)"
                }
              }
            }
          }
        }
      }
    }
  ],
  "files": {
    "includes": [
      "src/**/*.ts",
      "packages/**/*.ts",
      "scripts/**/*.ts",
      "e2e/**/*.ts",
      "*.ts",
      "*.mjs"
    ]
  }
}
