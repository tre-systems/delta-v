{
  "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all",
      "arrowParentheses": "always"
    }
  },
  "linter": {
    "rules": {
      "style": {
        "useConst": "error",
        "useTemplate": "warn",
        "useExponentiationOperator": "warn",
        "noNonNullAssertion": "off"
      },
      "complexity": {
        "useArrowFunction": "warn",
        "useFlatMap": "warn",
        "noForEach": "off"
      },
      "suspicious": {
        "noVar": "error",
        "noExplicitAny": "warn",
        "noDoubleEquals": "error"
      },
      "correctness": {
        "noUnusedVariables": "warn",
        "noUnusedImports": "error"
      }
    }
  },
  "files": {
    "includes": ["src/**/*.ts", "*.mjs"]
  }
}
